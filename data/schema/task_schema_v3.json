{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Semiconductor Gas-Sensing Benchmark V3 Alpha Task",
  "type": "array",
  "minItems": 46,
  "maxItems": 46,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "task_id",
      "benchmark_version",
      "benchmark_split",
      "task_type",
      "scenario_stage",
      "expected_output",
      "tool_mode",
      "tool_type",
      "target_dimensions",
      "hard_gate_checks",
      "failure_modes",
      "risk_level",
      "variant_group_id",
      "variant_type",
      "source_policy",
      "gold_response",
      "scoring_rubric",
      "prompt"
    ],
    "properties": {
      "task_id": {
        "type": "string",
        "pattern": "^V3-(SC|RB|LIVE)-[0-9]{3}$"
      },
      "benchmark_version": {
        "const": "v3-alpha"
      },
      "benchmark_split": {
        "enum": [
          "static_core",
          "robustness",
          "live_extension"
        ]
      },
      "task_type": {
        "enum": [
          "professional_judgment",
          "contextual_decision",
          "evidence_boundary",
          "experiment_design",
          "tool_use",
          "robustness_variant"
        ]
      },
      "scenario_stage": {
        "enum": [
          "文献分析",
          "实验设计",
          "实验进行",
          "结果分析",
          "下一步计划",
          "安全边界"
        ]
      },
      "expected_output": {
        "enum": [
          "风险识别与安全边界判断",
          "异常归因与验证路径",
          "实验设计与验证路径",
          "数据解释与证据边界",
          "下一步计划与路线取舍",
          "机理解释与边界判断",
          "情境化专业判断"
        ]
      },
      "tool_mode": {
        "enum": [
          "no_tool",
          "tool_enabled"
        ]
      },
      "tool_type": {
        "enum": [
          "no_tool",
          "calculator",
          "literature_retrieval",
          "table_analysis",
          "data_plotting",
          "safety_reference",
          "protocol_checklist"
        ]
      },
      "target_dimensions": {
        "type": "array",
        "minItems": 1,
        "items": {
          "enum": [
            "instruction_following",
            "professional_accuracy",
            "contextual_research_judgment",
            "evidence_grounding_uncertainty",
            "actionable_research_plan",
            "tool_use_quality",
            "safety_compliance_boundary"
          ]
        }
      },
      "hard_gate_checks": {
        "type": "array",
        "items": {
          "enum": [
            "G1_safety_hard_fail",
            "G2_professional_fact_hard_fail",
            "G3_evidence_fabrication_or_overclaim",
            "G4_instruction_violation",
            "G5_dangerous_tool_misuse",
            "G6_privacy_leakage"
          ]
        }
      },
      "failure_modes": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string"
        }
      },
      "risk_level": {
        "enum": [
          "low",
          "medium",
          "high"
        ]
      },
      "variant_group_id": {
        "type": "string"
      },
      "variant_type": {
        "enum": [
          "base",
          "paraphrase",
          "distractor",
          "contradiction",
          "multi_turn",
          "adversarial_safety",
          "live"
        ]
      },
      "parent_task_id": {
        "type": [
          "string",
          "null"
        ]
      },
      "domain": {
        "type": "string"
      },
      "material_system": {
        "type": "string"
      },
      "prompt": {
        "type": "string",
        "minLength": 20
      },
      "input_artifact": {
        "type": "object"
      },
      "expected_tool_behavior": {
        "type": "string"
      },
      "answer_format": {
        "type": "string"
      },
      "source_policy": {
        "enum": [
          "public_literature_analog",
          "abstract_lab_workflow",
          "public_safety_reference",
          "synthetic_design_task",
          "synthetic_calculation_task",
          "synthetic_curve_data",
          "synthetic_decision_task",
          "abstract_sop_checklist",
          "abstract_scaleup_workflow",
          "synthetic_product_gate",
          "live_extension_synthetic_public"
        ]
      },
      "gold_response": {
        "type": "object"
      },
      "scoring_rubric": {
        "type": "object"
      },
      "privacy_note": {
        "type": "string"
      },
      "difficulty": {
        "enum": [
          "basic",
          "intermediate",
          "advanced"
        ]
      },
      "tags": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "audit_notes": {
        "type": "string"
      }
    }
  }
}
